<?xml version="1.0"?>
<robot xmlns:xacro="http://www.ros.org/wiki/xacro">

  <!-- ============================================================================
       Parallel-jaw gripper Xacro macro for the factory robot.
       
       Structure:
         gripper_base_link (fixed to top_mount_link)
           ├── left_finger_link (prismatic joint)
           └── right_finger_link (prismatic mimic joint, opposite direction)
       
       Control: ros2_control position_controllers/JointGroupPositionController
       Command: Float64MultiArray on /gripper_controller/commands
                Value 0.0 => fully open, 0.04 => fully closed
       ============================================================================ -->

  <xacro:macro name="parallel_gripper" params="parent xyz rpy">

    <!-- === Gripper base plate === -->
    <link name="gripper_base_link">
      <visual>
        <origin xyz="0 0 0" rpy="0 0 0"/>
        <geometry>
          <box size="0.15 0.10 0.02"/>
        </geometry>
        <material name="orange">
          <color rgba="1.0 0.5 0.0 1.0"/>
        </material>
      </visual>
      <collision>
        <origin xyz="0 0 0" rpy="0 0 0"/>
        <geometry>
          <box size="0.15 0.10 0.02"/>
        </geometry>
      </collision>
      <inertial>
        <mass value="0.3"/>
        <inertia ixx="0.0001" ixy="0" ixz="0" iyy="0.0001" iyz="0" izz="0.0001"/>
      </inertial>
    </link>

    <joint name="gripper_base_joint" type="fixed">
      <parent link="${parent}"/>
      <child link="gripper_base_link"/>
      <origin xyz="${xyz}" rpy="${rpy}"/>
    </joint>

    <!-- === Left finger === -->
    <link name="left_finger_link">
      <visual>
        <origin xyz="0 0.03 0.04" rpy="0 0 0"/>
        <geometry>
          <box size="0.04 0.02 0.08"/>
        </geometry>
        <material name="silver">
          <color rgba="0.7 0.7 0.7 1.0"/>
        </material>
      </visual>
      <collision>
        <origin xyz="0 0.03 0.04" rpy="0 0 0"/>
        <geometry>
          <box size="0.04 0.02 0.08"/>
        </geometry>
      </collision>
      <inertial>
        <mass value="0.05"/>
        <inertia ixx="0.00001" ixy="0" ixz="0" iyy="0.00001" iyz="0" izz="0.00001"/>
      </inertial>
    </link>

    <joint name="left_finger_joint" type="prismatic">
      <parent link="gripper_base_link"/>
      <child link="left_finger_link"/>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <axis xyz="0 1 0"/>
      <limit lower="0.0" upper="0.04" effort="10.0" velocity="0.1"/>
    </joint>

    <!-- === Right finger (mimics left finger in opposite direction) === -->
    <link name="right_finger_link">
      <visual>
        <origin xyz="0 -0.03 0.04" rpy="0 0 0"/>
        <geometry>
          <box size="0.04 0.02 0.08"/>
        </geometry>
        <material name="silver"/>
      </visual>
      <collision>
        <origin xyz="0 -0.03 0.04" rpy="0 0 0"/>
        <geometry>
          <box size="0.04 0.02 0.08"/>
        </geometry>
      </collision>
      <inertial>
        <mass value="0.05"/>
        <inertia ixx="0.00001" ixy="0" ixz="0" iyy="0.00001" iyz="0" izz="0.00001"/>
      </inertial>
    </link>

    <joint name="right_finger_joint" type="prismatic">
      <parent link="gripper_base_link"/>
      <child link="right_finger_link"/>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <axis xyz="0 1 0"/>
      <limit lower="0.0" upper="0.04" effort="10.0" velocity="0.1"/>
      <!-- mimic: moves equally in opposite direction to left finger -->
      <mimic joint="left_finger_joint" multiplier="-1.0" offset="0.0"/>
    </joint>

    <!-- === Gazebo material hints === -->
    <gazebo reference="gripper_base_link">
      <material>Gazebo/Orange</material>
    </gazebo>
    <gazebo reference="left_finger_link">
      <material>Gazebo/Grey</material>
    </gazebo>
    <gazebo reference="right_finger_link">
      <material>Gazebo/Grey</material>
    </gazebo>

  </xacro:macro>

</robot>
